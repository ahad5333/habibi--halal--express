# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:5001

# Stripe publishable key (safe to expose — starts with pk_test_ or pk_live_)
# Get it at: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# PayPal client ID (leave blank to disable PayPal option)
# Get it at: https://developer.paypal.com/dashboard/applications
VITE_PAYPAL_CLIENT_ID=REPLACE_ME

# Google Maps API key (optional — enables address autocomplete on checkout)
# Get it at: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_KEY=REPLACE_ME

# Analytics (leave as mock values for dev — will simulate events in console)
VITE_GA_MEASUREMENT_ID=G-REPLACE_ME
VITE_FB_PIXEL_ID=REPLACE_ME
