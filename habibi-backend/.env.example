PORT=5001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────
# LOCAL DEV: use individual vars below
# PRODUCTION: set DATABASE_URL instead (overrides individual vars)
# e.g. DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

DB_USER=postgres
DB_HOST=localhost
DB_NAME=habibi_db
DB_PASSWORD=REPLACE_ME
DB_PORT=5432

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_ME_WITH_64_BYTE_HEX

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
FRONTEND_URL=http://localhost:5175

# ─── Stripe ───────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
PAYMENT_PROCESSOR=stripe
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── Square (alternative to Stripe — set PAYMENT_PROCESSOR=square) ───
SQUARE_ACCESS_TOKEN=REPLACE_ME
SQUARE_LOCATION_ID=REPLACE_ME
SQUARE_WEBHOOK_SIGNATURE_KEY=REPLACE_ME

# ─── PayPal ───────────────────────────────────────────────────
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=REPLACE_ME
PAYPAL_CLIENT_SECRET=REPLACE_ME
PAYPAL_MODE=sandbox

# ─── Offline payment instructions (shown to customers) ────────
ZELLE_EMAIL=payments@yourrestaurant.com
CASHAPP_CASHTAG=$YourCashTag

# ─── SMS (Twilio) ─────────────────────────────────────────────
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_PHONE_NUMBER=+1REPLACE_ME

# ─── Email (SMTP / Gmail) ─────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=REPLACE_ME
EMAIL_PASS=REPLACE_ME
EMAIL_FROM=Habibi Halal Express <noreply@yourrestaurant.com>

# ─── Google Maps (delivery fee + dispatch routing) ────────────
# https://console.cloud.google.com/ — enable Distance Matrix API
GOOGLE_MAPS_API_KEY=REPLACE_ME

# ─── Push Notifications (FCM) ────────────────────────────────
# https://console.firebase.google.com/ — Service Account JSON as single-line
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Restaurant Details (used in dispatch payloads) ───────────
RESTAURANT_ADDRESS=204 E Mosholu Pkwy S, Bronx, NY 10458
RESTAURANT_NAME=Habibi Halal Express
RESTAURANT_PHONE=+1REPLACE_ME
RESTAURANT_STREET=204 E Mosholu Pkwy S
RESTAURANT_CITY=Bronx
RESTAURANT_STATE=NY
RESTAURANT_ZIP=10458

# ─── Third-party Delivery (optional) ─────────────────────────
# DoorDash Drive: https://developer.doordash.com/
DOORDASH_DEVELOPER_ID=REPLACE_ME
DOORDASH_KEY_ID=REPLACE_ME
DOORDASH_SIGNING_SECRET=REPLACE_ME

# ─── Sentry Error Monitoring (optional) ──────────────────────
# https://sentry.io — leave blank to disable
SENTRY_DSN=
