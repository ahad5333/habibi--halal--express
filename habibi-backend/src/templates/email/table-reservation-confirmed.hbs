<div style="text-align:center;margin-bottom:24px;">
  <div style="display:inline-flex;align-items:center;justify-content:center;background:#f0fdf4;border:2px solid #22c55e;border-radius:50%;width:68px;height:68px;font-size:34px;">✅</div>
</div>

<h2 style="color:#0f172a;margin:0 0 8px;text-align:center;font-size:22px;">Your Table is Confirmed!</h2>
<p style="text-align:center;color:#64748b;font-size:14px;margin:0 0 24px;">We're looking forward to welcoming you, <strong style="color:#0f172a;">{{name}}</strong>.</p>

<div style="background:#fffbeb;border:2px solid #E5B64E;border-radius:12px;padding:20px 24px;margin:0 0 20px;">
  <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#92400e;margin:0 0 14px;">📋 Reservation Details</p>
  <table style="width:100%;border-collapse:collapse;font-size:14px;">
    <tr>
      <td style="color:#78716c;padding:7px 0;width:130px;vertical-align:top;">📍 Location</td>
      <td style="font-weight:600;color:#0f172a;padding:7px 0;">{{location}}</td>
    </tr>
    <tr>
      <td style="color:#78716c;padding:7px 0;vertical-align:top;">📅 Date</td>
      <td style="font-weight:600;color:#0f172a;padding:7px 0;">{{date}}</td>
    </tr>
    <tr>
      <td style="color:#78716c;padding:7px 0;vertical-align:top;">🕐 Time</td>
      <td style="font-weight:700;color:#b8860b;font-size:16px;padding:7px 0;">{{time}}</td>
    </tr>
    <tr>
      <td style="color:#78716c;padding:7px 0;vertical-align:top;">👥 Party Size</td>
      <td style="font-weight:600;color:#0f172a;padding:7px 0;">{{party_size}} guests</td>
    </tr>
    {{#if table_number}}
    <tr>
      <td style="color:#78716c;padding:7px 0;vertical-align:top;">🪑 Your Table</td>
      <td style="font-weight:700;color:#16a34a;font-size:15px;padding:7px 0;">{{table_number}}</td>
    </tr>
    {{/if}}
    <tr>
      <td style="color:#78716c;padding:7px 0;vertical-align:top;">🔖 Ref #</td>
      <td style="font-weight:600;color:#0f172a;padding:7px 0;font-family:monospace;">{{ref_number}}</td>
    </tr>
  </table>
</div>

<div style="background:#f8fafc;border-radius:10px;padding:16px 20px;margin:0 0 20px;font-size:13px;color:#475569;line-height:1.7;">
  <strong style="color:#0f172a;">A few things to know:</strong><br/>
  • Please arrive a few minutes before your reservation time.<br/>
  • Your table will be held for <strong>15 minutes</strong> past the booking time.<br/>
  • To modify or cancel, call us at <strong>(718) 367-7878</strong>.<br/>
  • Let us know of any dietary requirements when you arrive.
</div>

<p style="font-size:14px;color:#0f172a;text-align:center;margin:0 0 4px;">We can't wait to serve you.</p>
<p style="font-size:13px;color:#64748b;text-align:center;margin:0 0 20px;">— Habibi Halal Express 🥙</p>
