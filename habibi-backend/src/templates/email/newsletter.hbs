{{#if hero_text}}
<div style="background:{{banner_bg}};padding:1.75rem 2rem;text-align:center;border-radius:8px 8px 0 0;margin:-1.5rem -1.5rem 1.5rem">
  <p style="color:{{banner_text}};font-size:1.3rem;font-weight:800;margin:0;line-height:1.3">{{hero_text}}</p>
</div>
{{/if}}

<div style="font-size:15px;line-height:1.75;color:#1e293b">{{{body_html}}}</div>

{{#if cta_text}}{{#if cta_url}}
<div style="text-align:center;margin:1.75rem 0">
  <a href="{{cta_url}}" style="display:inline-block;background:#1e3a8a;color:#fff;padding:0.875rem 2.5rem;border-radius:6px;font-weight:700;font-size:0.875rem;text-decoration:none;letter-spacing:0.05em;text-transform:uppercase">{{cta_text}}</a>
</div>
{{/if}}{{/if}}

{{#if footer_note}}
<p style="font-size:0.78rem;color:#94a3b8;margin-top:1.25rem;border-top:1px solid #e2e8f0;padding-top:0.875rem">{{footer_note}}</p>
{{/if}}
