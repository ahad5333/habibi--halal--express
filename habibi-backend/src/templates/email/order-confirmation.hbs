<h2 style="color: #1e3a8a; margin-top: 0; font-size: 20px;">Thank You for Your Order!</h2>
<p>We've received your legendary order <strong>#{{order_number}}</strong> and our kitchen is jumping to action.</p>

<div style="background-color: #f8fafc; padding: 15px; border-radius: 8px; margin: 20px 0; border: 1px solid #e2e8f0;">
  <h3 style="margin-top: 0; font-size: 14px; color: #475569; text-transform: uppercase; letter-spacing: 0.5px;">Order Details</h3>
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr style="color: #64748b; font-size: 12px; text-transform: uppercase;">
        <th style="text-align: left; padding-bottom: 8px; border-bottom: 2px solid #e2e8f0;">Item</th>
        <th style="text-align: center; padding-bottom: 8px; border-bottom: 2px solid #e2e8f0;">Qty</th>
        <th style="text-align: right; padding-bottom: 8px; border-bottom: 2px solid #e2e8f0;">Price</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td style="padding: 10px 0; border-bottom: 1px solid #e2e8f0;">
          <div style="font-weight: 600; font-size: 14px;">{{name}}</div>
          {{#if selectedOption}}<div style="font-size: 12px; color: #64748b;">Option: {{selectedOption}}</div>{{/if}}
          {{#if selectedAddons}}<div style="font-size: 12px; color: #64748b;">Addons: {{join selectedAddons}}</div>{{/if}}
        </td>
        <td style="padding: 10px 0; text-align: center; border-bottom: 1px solid #e2e8f0; font-size: 14px;">x{{qty}}</td>
        <td style="padding: 10px 0; text-align: right; border-bottom: 1px solid #e2e8f0; font-size: 14px; font-weight: 500;">${{currency price}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <table style="width: 100%; margin-top: 15px; font-size: 14px;">
    <tr>
      <td style="padding: 4px 0; color: #64748b;">Subtotal</td>
      <td style="padding: 4px 0; text-align: right; font-weight: 500;">${{currency sub_total}}</td>
    </tr>
    {{#if tax}}
    <tr>
      <td style="padding: 4px 0; color: #64748b;">Tax</td>
      <td style="padding: 4px 0; text-align: right; font-weight: 500;">${{currency tax}}</td>
    </tr>
    {{/if}}
    {{#if delivery_fee}}
    <tr>
      <td style="padding: 4px 0; color: #64748b;">Delivery Fee</td>
      <td style="padding: 4px 0; text-align: right; font-weight: 500;">${{currency delivery_fee}}</td>
    </tr>
    {{/if}}
    {{#if service_fee}}
    <tr>
      <td style="padding: 4px 0; color: #64748b;">Service Fee</td>
      <td style="padding: 4px 0; text-align: right; font-weight: 500;">${{currency service_fee}}</td>
    </tr>
    {{/if}}
    {{#if tip}}
    <tr>
      <td style="padding: 4px 0; color: #64748b;">Tip</td>
      <td style="padding: 4px 0; text-align: right; font-weight: 500;">${{currency tip}}</td>
    </tr>
    {{/if}}
    {{#if discount}}
    <tr>
      <td style="padding: 4px 0; color: #34d399;">Discount</td>
      <td style="padding: 4px 0; text-align: right; color: #34d399; font-weight: 500;">-${{currency discount}}</td>
    </tr>
    {{/if}}
    <tr style="font-size: 16px; font-weight: 700; border-top: 2px solid #e2e8f0;">
      <td style="padding: 10px 0; color: #0f172a;">Total</td>
      <td style="padding: 10px 0; text-align: right; color: #1e3a8a;">${{currency total}}</td>
    </tr>
  </table>
</div>

<div style="margin: 25px 0; text-align: center;">
  <a href="{{trackingLink}}" class="cta-btn">TRACK YOUR ORDER</a>
</div>

<p style="font-size: 14px; color: #64748b;">Delivery Mode: <strong>{{delivery_method}}</strong></p>
{{#if delivery_address}}
<p style="font-size: 14px; color: #64748b;">Drop-off Address: <strong>{{delivery_address}}</strong></p>
{{/if}}
